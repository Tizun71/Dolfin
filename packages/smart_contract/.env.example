# --- Deployer / owner (Arbitrum Sepolia) ---
PRIVATE_KEY=

# --- Alchemy (RPC + ERC-4337 bundler), Arbitrum Sepolia ---
# RPC:     https://arb-sepolia.g.alchemy.com/v2/<API_KEY>
# Bundler: https://arb-sepolia.g.alchemy.com/v2/<API_KEY>   (Alchemy serves bundler on the same URL)
ALCHEMY_RPC_URL=
ALCHEMY_BUNDLER_URL=

# --- Session key (the AI relayer's signer) ---
# Separate EOA. Scoped + revocable; the relayer holds ONLY this key, never PRIVATE_KEY.
SESSION_KEY=

# --- Account salt (CREATE2) ---
ACCOUNT_SALT=00171141

# --- Demo policy (USD, human units; the script scales to 1e18) ---
POLICY_MAX_TRADE_USD=1000
POLICY_MAX_DAILY_USD=5000
POLICY_MAX_EXPOSURE_USD=5000
POLICY_MAX_LOSS_PER_DAY_USD=500
POLICY_EXPIRY_DAYS=7
