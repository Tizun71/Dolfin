HOSTNAME=localhost
# Comma-separated CORS allowlist for the browser frontend. Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=
PORT=
# Google AI API key — used by AdvisorNode (ChatGoogleGenerativeAI, gemini-2.0-flash-lite)
GOOGLE_API_KEY=

# --- Dolfin agent on-chain execution (Arbitrum Sepolia) ---
# Alchemy RPC + ERC-4337 bundler (same URL): https://arb-sepolia.g.alchemy.com/v2/<API_KEY>
ALCHEMY_RPC_URL=
ALCHEMY_BUNDLER_URL=
# Session key EOA the relayer signs with (scoped, revocable). NEVER the owner key.
# Dev/smoke CLI only — per-user agents use their own key from the DB (encrypted).
SESSION_KEY=
# Secret used to encrypt per-user session keys at rest (AES-256-GCM). 32+ chars, required.
SESSION_KEY_ENC_SECRET=
# Optional policy mirror overrides (defaults: 1000/5000/5000/500 USD, 7-day expiry)
POLICY_MAX_TRADE_USD=1000
POLICY_MAX_DAILY_USD=5000
POLICY_MAX_EXPOSURE_USD=5000
POLICY_MAX_LOSS_PER_DAY_USD=500
POLICY_EXPIRY_DAYS=7
DUNE_API_KEY=

# --- Dolfin agent scheduler ---
# Cron expression for the run-dolfin-agents tick (default: hourly).
DOLFIN_AGENT_CRON=0 * * * *

# Log level for the LogTape logger (debug|info|warning|error). Default: info.
LOG_LEVEL=info

# --- Dev/smoke CLI (agent:run) only ---
DEV_SMART_ACCOUNT=
DEV_USER_ID=

# --- Robinhood Chain testnet (cross-chain read-only, chainId 46630) ---
# Optional RPC override; falls back to the rate-limited public endpoint.
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
# Tokenized-stock tokens to read balances for, as a JSON array. Empty = equity side shows $0.
# Fill addresses from the Robinhood Chain faucet. Set chainlinkFeed for a live USD price.
# Example: [{"symbol":"TSLA","address":"0x...","decimals":18,"chainlinkFeed":"0x..."}]
ROBINHOOD_STOCK_TOKENS=